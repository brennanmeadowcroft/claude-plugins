{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -d \"${CLAUDE_PLUGIN_ROOT}/servers/todoist/node_modules\" ] || (cd \"${CLAUDE_PLUGIN_ROOT}/servers/todoist\" && npm install)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "project-index",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/extract_frontmatter.py\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "project-index",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/extract_frontmatter.py\""
          }
        ]
      }
    ]
  }
}
